{
  "rules": {
    "users": {
      ".indexOn": ["calToken"],
      "$uid": {
        // You can read your own data, OR your partner's data if you're linked to them
        ".read": "auth != null && (auth.uid === $uid || root.child('users').child(auth.uid).child('linkedTo').val() === $uid)",
        // You can write your own data, OR your partner's if you're linked to them.
        // (When linked, the app stores shared viewings/wishlist under the partner's node — see getDataUid() in auth.js.)
        ".write": "auth != null && (auth.uid === $uid || root.child('users').child(auth.uid).child('linkedTo').val() === $uid)"
      }
    },
    "invites": {
      "$code": {
        // Reading requires knowing the exact code (no listing of all invites)
        ".read": "auth != null",
        // Anyone signed in can create a new code or delete one (redeeming deletes it),
        // but only the creator can modify an existing invite
        ".write": "auth != null && (!data.exists() || !newData.exists() || data.child('uid').val() === auth.uid)"
      }
    }
  }
}
